<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <UI>
      <Dialog Id="NavidromeConfiguration" Width="370" Height="270" Title="[ProductName] Setup" NoMinimize="yes">
        <!--Header-->
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes">
          <Text>{\WixUI_Font_Title}Configuration</Text>
        </Control>
        <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes">
          <Text>Configuration</Text>
        </Control>
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <!--Properties-->
        <Control Id="NameLabel" Type="Text" X="30" Y="60" Width="100" Height="15" TabSkip="no" Text="&amp;Port:" />
        <Control Id="NameEdit" Type="Edit" X="30" Y="72" Width="220" Height="18" Property="NAVIDROME_PORT" Text="{80}" />

        <Control Id="NameLabel" Type="Text" X="30" Y="84" Width="100" Height="15" TabSkip="no" Text="&amp;Music Directory:" />
        <Control Id="NameEdit" Type="Edit" X="30" Y="96" Width="220" Height="18" Property="NAVIDROME_MUSICDIR" Text="{80}" />

        <Control Id="NameLabel" Type="Text" X="30" Y="108" Width="100" Height="15" TabSkip="no" Text="&amp;Data Directory:" />
        <Control Id="NameEdit" Type="Edit" X="30" Y="120" Width="220" Height="18" Property="NAVIDROME_DATADIR" Text="{80}" />

        <!--Footer-->
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Back">
          <Publish Event="NewDialog" Value="InstallDirDlg">1</Publish>
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Next">
          <Publish Event="SpawnWaitDialog" Value="WaitForCostingDlg">CostingComplete = 1</Publish>
          <Condition Action="disable"><![CDATA[NAVIDROME_PORT = "" || NAVIDROME_MUSICDIR = "" || NAVIDROME_DATADIR = "" ]]></Condition>
          <Condition Action="enable"><![CDATA[NAVIDROME_PORT <> "" && NAVIDROME_MUSICDIR <> "" && NAVIDROME_DATADIR <> "" ]]></Condition>
          <Publish Event="NewDialog" Value="VerifyReadyDlg">NAVIDROME_PORT</Publish>
          <Publish Event="NewDialog" Value="VerifyReadyDlg">NAVIDROME_MUSICDIR</Publish>
          <Publish Event="NewDialog" Value="VerifyReadyDlg">NAVIDROME_DATADIR</Publish>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
      </Dialog>
    </UI>
  </Fragment>
</Wix>
